{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "homeplanr",
  "version": "0.12.0",
  "identifier": "com.kapuchai.homeplanr",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "homeplanr",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "zoomHotkeysEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "fileAssociations": [
      {
        "ext": ["homeplanr"],
        "name": "homeplanr project",
        "description": "homeplanr floor-plan project",
        "mimeType": "application/x-homeplanr",
        "role": "Editor"
      }
    ],
    "linux": {
      "deb": {
        "desktopTemplate": "./homeplanr.desktop",
        "files": {
          "/usr/share/mime/packages/homeplanr.xml": "./mime/homeplanr.xml"
        }
      },
      "rpm": {
        "desktopTemplate": "./homeplanr.desktop",
        "files": {
          "/usr/share/mime/packages/homeplanr.xml": "./mime/homeplanr.xml"
        }
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
