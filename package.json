{
  "name": "homeplanr",
  "private": true,
  "version": "0.1.0",
  "description": "Home planning app — draw floor plans in 2D, furnish them, and view in 3D",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b",
    "lint": "oxlint",
    "lint:colors": "! git grep -nE '#[0-9a-fA-F]{3,8}\\b|rgba?\\(' -- 'src/**/*.tsx' 'src/**/*.ts' ':!src/theme' ':!src/catalog' ':!src/**/*.test.ts' ':!src/test'",
    "tauri": "tauri",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-fs": "^2",
    "earcut": "3.2.3",
    "immer": "^11",
    "nanoid": "^5.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "three": "0.185.1",
    "zundo": "2.3.0",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tauri-apps/cli": "^2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^6.0.3",
    "fast-check": "^4",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.0"
  }
}
